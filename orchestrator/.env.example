# ============================================================================
# NexusOPS Orchestrator Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================================================
# AWS Configuration
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ============================================================================
# DynamoDB Table Names (6 tables used by orchestrator)
# ============================================================================
DYNAMODB_TABLE_EXECUTION_RECORDS=ExecutionRecords
DYNAMODB_TABLE_EXECUTION_LOGS=ExecutionLogs
DYNAMODB_TABLE_APPROVAL_RECORDS=ApprovalRecords
DYNAMODB_TABLE_CONTEXT_CHUNKS=ContextChunks
DYNAMODB_TABLE_TOOL_REGISTRY=ToolRegistry
DYNAMODB_TABLE_RISK_REGISTRY=RiskRegistry

# ============================================================================
# SNS Configuration
# ============================================================================
# Topic ARN for approval notifications
SNS_TOPIC_ARN_APPROVALS=arn:aws:sns:us-east-1:123456789012:nexusops-approvals

# ============================================================================
# GitHub Integration
# ============================================================================
# Personal access token for repository retrieval
# Generate at: https://github.com/settings/tokens
# Required scopes: repo (for private repos), public_repo (for public repos)
GITHUB_API_TOKEN=ghp_xxxxxxxxxxxxx

# ============================================================================
# Amazon Bedrock Configuration
# ============================================================================
# Model ID for Claude 3 Sonnet
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.1

# ============================================================================
# BFF Integration
# ============================================================================
# URL for WebSocket notifications back to BFF
BFF_URL=http://localhost:8000

# ============================================================================
# Governance Limits (Phase 9)
# ============================================================================
# Maximum total tokens per execution (input + output)
MAX_TOKEN_BUDGET=50000

# Maximum tool invocations per execution
MAX_INVOCATION_COUNT=10

# Risk recurrence threshold (high-risk plans blocked after this many occurrences)
RISK_RECURRENCE_THRESHOLD=5

# ============================================================================
# Approval Workflow
# ============================================================================
# Approval timeout in minutes
APPROVAL_TIMEOUT_MINUTES=15

# Escalation timeout in minutes (when to notify secondary approvers)
APPROVAL_ESCALATION_MINUTES=10

# ============================================================================
# Notes
# ============================================================================
# - All DynamoDB tables must exist before deployment
# - SNS topic must be created and subscribed to notification endpoints
# - GitHub token must have appropriate repository access
# - Bedrock model must be enabled in your AWS account
# - Token budget and invocation limits prevent runaway costs
