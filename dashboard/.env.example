# ============================================================================
# NexusOPS Dashboard Environment Configuration
# ============================================================================
# Copy this file to .env.local for local development
# Copy this file to .env.production for production builds
# DO NOT commit .env.local or .env.production to version control

# ============================================================================
# BFF API Configuration
# ============================================================================
# Local development
NEXT_PUBLIC_BFF_URL=http://localhost:8000

# Production (uncomment and update for production deployment)
# NEXT_PUBLIC_BFF_URL=https://api.nexusops.ai

# ============================================================================
# Notes
# ============================================================================
# - NEXT_PUBLIC_ prefix makes variables available in browser
# - Update BFF_URL to match your deployed API Gateway endpoint
# - For Amplify deployment, set environment variables in Amplify Console
